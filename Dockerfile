# Generated by GitHub Copilot
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HOST=0.0.0.0 \
    PORT=8010 \
    UVICORN_WORKERS=1

WORKDIR /app

RUN adduser --disabled-password --gecos "" --uid 10001 appuser

COPY requirements.txt ./requirements.txt
RUN python -m pip install --upgrade pip && pip install -r requirements.txt

COPY api ./api
COPY src ./src
COPY README.md ./README.md

EXPOSE 8010

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import sys,urllib.request; urllib.request.urlopen('http://127.0.0.1:8010/health/liveness', timeout=3); sys.exit(0)"

USER appuser

CMD ["sh", "-c", "uvicorn api.main:app --host ${HOST} --port ${PORT} --workers ${UVICORN_WORKERS} --timeout-keep-alive 30"]
